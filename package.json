{
  "name": "lockasaur",
  "productName": "Lockasaur",
  "executableName": "Lockasaur",
  "version": "2.0.0",
  "author": {
    "name": "Sam",
    "email": "cryptox.sam@outlook.com"
  },
  "copyright": "Copyright © 2026 Lockasaur Application",
  "description": "Encryption with bite: encrypt files locally with a password",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "scripts": {
    "serve": "vite --host 127.0.0.1",
    "electron:serve": "node scripts/electron-dev.mjs",
    "build": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "electron:build": "npm run build && npm run build:electron && node scripts/package-app.mjs",
    "electron:generate-icons": "node scripts/generate-icons.mjs",
    "electron:generate-appicon": "node scripts/generate-appicon.mjs",
    "test:unit": "jest --runInBand",
    "test:e2e": "npm run build && npm run build:electron && node tests/e2e/smoke.js",
    "test:large": "jest --runInBand --testMatch \"<rootDir>/tests/large/**/*.spec.js\"",
    "lint": "eslint \"src/**/*.{js,vue}\" \"tests/**/*.js\" \"scripts/**/*.mjs\" \"*.config.{js,cjs,mjs}\"",
    "lint:fix": "npm run lint -- --fix",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "main": "dist-electron/background.cjs",
  "engines": {
    "node": ">=24 <27"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "libsodium-wrappers-sumo": "^0.8.4",
    "pinia": "^3.0.4",
    "tar-fs": "^3.1.2",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/compiler-sfc": "^3.5.34",
    "@vue/test-utils": "^2.4.0",
    "babel-jest": "^30.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jest": "^30.0.0",
    "jest-environment-node": "^30.0.0",
    "prettier": "3.9.5",
    "sass": "^1.94.2",
    "vite": "^8.0.0",
    "vue-eslint-parser": "^10.4.1"
  }
}
