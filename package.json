{
  "name": "cryptox",
  "productName": "Cryptox",
  "executableName": "Cryptox",
  "version": "0.3.3-alpha",
  "author": {
    "name": "Samuel Palomo Esteban",
    "email": "samuelpe@outlook.com"
  },
  "copyright": "Copyright © 2020 Samuel Palomo Esteban",
  "description": "App to encrypt files easier",
  "license": "MIT",
  "private": true,
  "scripts": {
    "serve": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "test:unit": "jest --runInBand",
    "test:e2e": "npm run build && npm run build:electron && node tests/e2e/smoke.js",
    "lint": "eslint \"src/**/*.{js,vue}\" \"tests/**/*.js\" \"scripts/**/*.mjs\" \"*.config.{js,cjs}\"",
    "lintfix:js": "eslint 'src/**/*.js' --fix",
    "lintfix:vue": "eslint 'src/**/*.vue' --fix",
    "electron:build": "npm run build && npm run build:electron && electron-builder --config electron-builder.config.cjs --publish never",
    "electron:serve": "node scripts/electron-dev.mjs",
    "electron:generate-icons": "electron-icon-builder --input=./public/icon.png --output=build --flatten",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "main": "dist-electron/background.cjs",
  "engines": {
    "node": ">=24 <27"
  },
  "dependencies": {
    "animate.css": "^3.7.2",
    "electron-log": "^4.4.0",
    "libsodium-wrappers-sumo": "^0.8.4",
    "materialize-css": "^1.0.0-rc.2",
    "pinia": "^3.0.0",
    "tar-fs": "^3.1.2",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/compiler-sfc": "^3.5.0",
    "@vue/test-utils": "^2.4.0",
    "babel-jest": "^30.0.0",
    "electron": "^40.10.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "jest": "^30.0.0",
    "jest-environment-node": "^30.0.0",
    "prettier": "3.8.3",
    "sass": "^1.94.2",
    "vite": "^8.0.0",
    "vue-eslint-parser": "^9.4.0"
  }
}
